# Firebase (same project can be shared with pointed-app or new)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Only this Gmail can sign in to /admin
VITE_ADMIN_EMAIL=you@gmail.com
VITE_ADMIN_FIRST_NAME=Jeff

# Optional: Open-Meteo uses lat/lon (defaults to San Francisco)
VITE_WEATHER_LAT=37.7749
VITE_WEATHER_LON=-122.4194
